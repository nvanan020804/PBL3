    <style>
        .logo {
            width: auto;
        }
        .logo img {
            height: 42px;
            background-size: cover;
        }
        header li a {
             color: #34348E !important;
             font-size: 16px;
             font-style: normal;
             font-weight: 400;
             width: max-content;
             display: block;
             font-family: 'AvertaStdPE-Bold';
         }
        header ul.dropdown-menu.show li a {
            width: 198px;
        }
        header ul.dropdown-menu.show li a:hover {
            color: #2196F3 !important;
        }
        header {
            background: #fff;
        }

        .block-slide-banner .box-info a {
            display: flex;
            height: 56px;
            padding: 12px 16px;
            justify-content: center;
            align-items: center;
            border: 2px solid #014ECF;
            width: max-content;
            text-decoration: none;
            font-size: 16px;
            font-style: normal;
            font-weight: 700;
            text-transform: uppercase;
        }
        .block-slide-banner .box-info a:hover {
            border: 2px solid #013793;
            background: #01379324;
            transition: 0.4s;
        }
        ul.dropdown-menu.show {
            padding: 10px;
        }
        .home-search img {
            width: 30px;
            height: auto;
        }

        .home-search button {
            border: none;
            background: no-repeat;
        }
        .home-search input {
            border: none;
            font-size: 13px;
        }
        .home-search {
            border: 1px solid #80808057;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 5px;
            display: none;
        }
        .home-search .form-control:focus {
            border-color: #fff;
            outline: none;
            box-shadow: none;
        }
        .icon-search {
            cursor: pointer;
        }
        .home-search.show {
            display: block;
        }
        .search-li {
            margin-left: 50px;
        }
        .nav-link {
            cursor: pointer;
        }
        .display-out-of-business {
            color: red;
            text-align: center;
            text-transform: uppercase;
            font-weight: bold;
            font-size: 14px;
        }
        @media (max-width: 768px) {
            header ul.dropdown-menu.show li a {
                width: max-content;
            }
            .home-search.show {
                margin-bottom: 16px;
            }
            .icon-search {
                margin: 10px 0;
            }
            .search-li {
                margin-left: 0;
            }
        }
    </style>
</head>

<body>
<!-- gtm_code_body -->
    <!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MPLX8J2"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->

<!-- fbsdk_code_body -->

<header class="header-top sticky-top">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-12 col-sm-12">
                <nav class="navbar navbar-expand-lg">
                    <a class="navbar-brand logo d-lg-none" href="/">
                        <img loading="lazy" src="/catalog/view/theme/fashion_flavor/images/placeholder-img.jpg" data-src="https://cdn.bestme.vn/images/bestme/logo-cp2.png" alt="logo">
                    </a>
                    <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarTogglerDemo01" aria-controls="navbarTogglerDemo01" aria-expanded="false" aria-label="Toggle navigation">
                        <svg width="14" height="10" viewBox="0 0 14 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M1 1H13M1 5H13M1 9H13" stroke="#272D37" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarTogglerDemo01">
                        <a class="navbar-brand logo d-lg-block d-none" href="/">
                            <img loading="lazy" src="/catalog/view/theme/fashion_flavor/images/placeholder-img.jpg" data-src="https://cdn.bestme.vn/images/bestme/logo-cp2.png" alt="logo">
                        </a>
                        <ul class="navbar-nav ml-auto">
                            <li class="nav-item">
                                <a class="nav-link" href="ve-dhc-viet-nam">Về chúng tôi</a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" data-toggle="dropdown" role="button" aria-expanded="false">Sản phẩm</a>
                                <ul class="dropdown-menu" role="menu">
                                    <li><a href="danh-muc/my-pham">Mỹ phẩm</a></li>
                                    <li><a href="danh-muc/thuc-pham-chuc-nang">Thực phẩm bảo vệ sức khỏe</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" data-toggle="dropdown" role="button" aria-expanded="false">Giải pháp</a>
                                <ul class="dropdown-menu" role="menu">
                                                                            <li><a href="https://dhcvietnam.com.vn/danh-muc/duong-da-mua-kho">Dưỡng da mùa khô</a></li>
                                                                            <li><a href="https://dhcvietnam.com.vn/danh-muc/lam-sach-sau">Làm sạch sâu</a></li>
                                                                            <li><a href="https://dhcvietnam.com.vn/danh-muc/dong-san-pham-chong-lao-hoa">Chống lão hoá da</a></li>
                                                                            <li><a href="https://dhcvietnam.com.vn/danh-muc/vitamin-khoang-chat">Vitamin - Khoáng chất cho cơ thể</a></li>
                                                                    </ul>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="hoi-dap">Hỏi đáp</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="doi-tac">Đối tác</a>
                            </li>
                            <li class="nav-item d-flex align-items-center search-li">
                                <img src="/catalog/view/theme/fashion_flavor/images/icons/search.png" alt="icon" class="icon-search" width="30px">
                                <form class="elastic-search home-search" action="https://dhcvietnam.com.vn/danh-muc" method="get">
                                    <div class="d-flex align-items-center">
                                        <input aria-label="search" data-bs-toggle="dropdown" aria-expanded="false" autocomplete="off" type="text" class="form-control" placeholder="Tìm kiếm sản phẩm" name="search">

                                        <button type="submit" aria-label="submit">
                                            <img src="/catalog/view/theme/fashion_flavor/images/icons/search.png" alt="icon">
                                        </button>
                                    </div>
                                </form>
                            </li>
                        </ul>
                    </div>
                </nav>
            </div>
        </div>
