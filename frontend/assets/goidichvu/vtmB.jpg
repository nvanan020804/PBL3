<script>
    $( ".view-more-product-new" ).click(function() {
        $('.description-product').toggleClass("show");
        if ($(".description-product").hasClass( "show" )) {
            $(".view-more-product-new").text("Thu gọn");
        }
        else {
            $(".view-more-product-new").text("Xem thêm thông tin sản phẩm");
        }
    });

    $(document).ready(function () {
        if (jQuery('#add-to-cart .color-detail input').length) {
            ajaxChangeVersion();
        }
        jQuery('#add-to-cart .color-detail input').on('click', function () {
            ajaxChangeVersion();
        });
    });

    function ajaxChangeVersion() {
        $.ajax({
            url: 'index.php?route=product/product/updateCartWhenChangeVersion',
            type: 'post',
            data: $('#add-to-cart').serialize(),
            dataType: 'json',
            beforeSend: function() {
                //TODO loading
            },
            complete: function() {
                //TODO loaded
            },
            success: function(json) {
                if (json['success']) {
                    updateHtmlVersion(json['sale_on_out_of_stock'], json['product_version']);
                } else {
                    jQuery('#add-to-cart button').attr('data-status', 'disabled');
                }
            },
            error: function(xhr, ajaxOptions, thrownError) {
                alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
            }
        });
    }

    function updateHtmlVersion(sale_on_out_of_stock, product) {
        //update price
        if (product['price'] == 0) {
            var compare_price = parseInt(product['compare_price_format']);
            html_price = (compare_price === 0 ?
                '<a href="#modal-buy-for-contact" rel="modal:open" class="btn btn-add">' + '<span class="price-new text-white">' + 'Liên hệ' + '</span></a>'
                : '<span class="price-new">' + product['compare_price_format'].replaceAll('VND', 'đ')) +'</span><span class="price-old"></span>';
            jQuery('.product-teaser-fix .second-color').html(' - ' + product['version'] + (compare_price === 0 ? '' : ' - ' + product['compare_price_format'].replaceAll('VND', 'đ')));
        } else {
            if (parseInt(product['price_format']) === 0) {
                html_price = '<a href="#modal-buy-for-contact" rel="modal:open" class="btn btn-add">' + '<span class="price-new text-white">' + 'Liên hệ' + '</span></a>';
            } else {
                html_price = '<span class="price-old">' + product['compare_price_format'].replaceAll('VND', 'đ') + '</span><span class="price-new">' + product['price_format'].replaceAll('VND', 'đ') + '</span>';
                jQuery('.product-teaser-fix .second-color').html(product['version'].replaceAll('VND', 'đ') + ' - ' + product['price_format'].replaceAll('VND', 'đ'));
            }
        }

        jQuery('.price-detail').html(html_price);
        // version
        if (product['version']) {
            // form mua tra gop
            var version = product['version'].replace(",", " - ")
            $('input#pAttribute').val(version)
        }

        // set default values
        product.image = product.image ? product.image : jQuery('#product-image-default-src').val();
        product.image_alt = product.image_alt ? product.image_alt : '';
        if (product.image) {
            jQuery('.swiper-slide-active .default-active').attr('src', product.image);
        }
    }

    new Swiper(".swiper-detail", {
        slidesPerView: 1,
        navigation: {
            nextEl: ".swiper-detail .swiper-button-next",
            prevEl: ".swiper-detail .swiper-button-prev",
        },
    });

    new Swiper(".swiper-popular-related-products", {
        slidesPerView: 2.5,
        pagination: {
            el: ".swiper-popular-related-products .swiper-pagination",
            dynamicBullets: true,
            clickable: true,
        },
        breakpoints: {
            // when window width is <= 320px
            320: {
                slidesPerView: 2,
                spaceBetween: 8
            },
            // when window width is <= 480px
            480: {
                slidesPerView: 2,
                spaceBetween: 8
            },
            768: {
                slidesPerView: 2,
                spaceBetween: 8
            },
            991: {
                slidesPerView: 3.5,
                spaceBetween: 8
            },
            // when window width is <= 640px
            1200: {
                slidesPerView: 3.5,
                spaceBetween: 8
            }
        },
    });
    new Swiper(".swiper-follow-dhc", {
        slidesPerView: 4,
        pagination: {
            el: ".swiper-follow-dhc .swiper-pagination",
            dynamicBullets: true,
            clickable: true,
        },
        breakpoints: {
            // when window width is <= 320px
            320: {
                slidesPerView: 2,
                spaceBetween: 0
            },
            // when window width is <= 480px
            480: {
                slidesPerView: 2,
                spaceBetween: 0
            },
            768: {
                slidesPerView: 2,
                spaceBetween: 20
            },
            991: {
                slidesPerView: 3,
                spaceBetween: 20
            },
            // when window width is <= 640px
            1200: {
                slidesPerView: 4,
                spaceBetween: 30
            }
        },
    });


    jQuery('.menu-tabs a').on('click', function (e) {
        e.preventDefault();
        $('.menu-tabs a').removeClass('active');
        let keyActive = $(this).attr('key-link-go-to');
        $("#panelsStayOpen-collapseTwo-" + keyActive).removeClass("show");
        $("#panelsStayOpen-headingTwo-" + keyActive + "button").addClass("collapsed");
        switch ($(this).attr('key-link-go-to')) {
            case "0":
                // add show
                $("#panelsStayOpen-collapseTwo-0").addClass("show");
                $("#panelsStayOpen-headingTwo-0 button").removeClass("collapsed");
                // remove show
                $("#panelsStayOpen-collapseTwo-1").removeClass("show");
                $("#panelsStayOpen-headingTwo-1 button").addClass("collapsed");
                $("#panelsStayOpen-collapseTwo-2").removeClass("show");
                $("#panelsStayOpen-headingTwo-2 button").addClass("collapsed");
                $("#panelsStayOpen-collapseTwo-3").removeClass("show");
                $("#panelsStayOpen-headingTwo-3 button").addClass("collapsed");
                $("#panelsStayOpen-collapseTwo-4").removeClass("show");
                $("#panelsStayOpen-headingTwo-4 button").addClass("collapsed");
                $(this).toggleClass('active');
                $('html,body').animate({
                        scrollTop: $("#panelsStayOpen-headingTwo-0").offset().top - 130},
                    'fast');
                break;
            case "1":
                // add show
                $("#panelsStayOpen-collapseTwo-1").addClass("show");
                $("#panelsStayOpen-headingTwo-1 button").removeClass("collapsed");
                // remove show
                $("#panelsStayOpen-collapseTwo-0").removeClass("show");
                $("#panelsStayOpen-headingTwo-0 button").addClass("collapsed");
                $("#panelsStayOpen-collapseTwo-2").removeClass("show");
                $("#panelsStayOpen-headingTwo-2 button").addClass("collapsed");
                $("#panelsStayOpen-collapseTwo-3").removeClass("show");
                $("#panelsStayOpen-headingTwo-3 button").addClass("collapsed");
                $("#panelsStayOpen-collapseTwo-4").removeClass("show");
                $("#panelsStayOpen-headingTwo-4 button").addClass("collapsed");
                $(this).toggleClass('active');
                $('html,body').animate({
                        scrollTop: $("#panelsStayOpen-headingTwo-1").offset().top - 130},
                    'fast');
                break;
            case "2":
                // add show
                $("#panelsStayOpen-collapseTwo-2").addClass("show");
                $("#panelsStayOpen-headingTwo-2 button").removeClass("collapsed");
                // remove show
                $("#panelsStayOpen-collapseTwo-0").removeClass("show");
                $("#panelsStayOpen-headingTwo-0 button").addClass("collapsed");
                $("#panelsStayOpen-collapseTwo-1").removeClass("show");
                $("#panelsStayOpen-headingTwo-1 button").addClass("collapsed");
                $("#panelsStayOpen-collapseTwo-3").removeClass("show");
                $("#panelsStayOpen-headingTwo-3 button").addClass("collapsed");
                $("#panelsStayOpen-collapseTwo-4").removeClass("show");
                $("#panelsStayOpen-headingTwo-4 button").addClass("collapsed");
                $(this).toggleClass('active');
                $('html,body').animate({
                        scrollTop: $("#panelsStayOpen-headingTwo-2").offset().top - 130},
                    'fast');
                break;
            case "3":
                // add show
                $("#panelsStayOpen-collapseTwo-3").addClass("show");
                $("#panelsStayOpen-headingTwo-3 button").removeClass("collapsed");
                // remove show
                $("#panelsStayOpen-collapseTwo-2").removeClass("show");
                $("#panelsStayOpen-headingTwo-2 button").addClass("collapsed");
                $("#panelsStayOpen-collapseTwo-0").removeClass("show");
                $("#panelsStayOpen-headingTwo-0 button").addClass("collapsed");
                $("#panelsStayOpen-collapseTwo-1").removeClass("show");
                $("#panelsStayOpen-headingTwo-1 button").addClass("collapsed");
                $("#panelsStayOpen-collapseTwo-4").removeClass("show");
                $("#panelsStayOpen-headingTwo-4 button").addClass("collapsed");
                $(this).toggleClass('active');
                $('html,body').animate({
                        scrollTop: $("#panelsStayOpen-headingTwo-3").offset().top - 130},
                    'fast');
                break;
            case "4":
                // add show
                $("#panelsStayOpen-collapseTwo-4").addClass("show");
                $("#panelsStayOpen-headingTwo-4 button").removeClass("collapsed");
                // remove show
                $("#panelsStayOpen-collapseTwo-2").removeClass("show");
                $("#panelsStayOpen-headingTwo-2 button").addClass("collapsed");
                $("#panelsStayOpen-collapseTwo-0").removeClass("show");
                $("#panelsStayOpen-headingTwo-0 button").addClass("collapsed");
                $("#panelsStayOpen-collapseTwo-1").removeClass("show");
                $("#panelsStayOpen-headingTwo-1 button").addClass("collapsed");
                $("#panelsStayOpen-collapseTwo-3").removeClass("show");
                $("#panelsStayOpen-headingTwo-3 button").addClass("collapsed");
                $(this).toggleClass('active');
                $('html,body').animate({
                        scrollTop: $("#panelsStayOpen-headingTwo-4").offset().top - 130},
                    'fast');
                break;
            case "review":
                $('html,body').animate({
                        scrollTop: $(".evaluate").offset().top - 130},
                    'fast');
                $(this).toggleClass('active');
        }
    });

    $(function() {
        //caches a jQuery object containing the header element
        var header = $(".header-product-fix");
        $(window).scroll(function() {
            var scroll = $(window).scrollTop();
            if ($(".menu-tabs").length == 0) {
                return;
            }

            if ($(".menu-tabs").position().top < scroll - 20) {
                $(".menu-tabs").addClass("fixed");
            }

            if (scroll >= 600) {
                header.addClass("show");
            } else {
                header.removeClass("show");
                $(".menu-tabs").removeClass("fixed");
            }

        });
    });
</script>
