    font-family: "Inter", sans-serif;
}
a:hover {
    text-decoration: none !important;
}
.sticky-top {
    z-index: 999999;
}
.breadcrumb {
    padding: 0;
    margin-bottom: 0;
    list-style: none;
    background-color: unset;
    padding-top: 16px;
}
.breadcrumb ol li a,.breadcrumb ol li {
    color: #515157;
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 140%;
}

.swiper-pagination-bullet {
    transition: .2s transform, .2s left;
    width: 30PX;
    margin: 0;
    border-radius: 0;
    height: 5px;
    bottom: 0;
}

.swiper-pagination-bullet-active {
    background: #014ECF;
}

.swiper-pagination-bullets-dynamic .swiper-pagination-bullet-active-next,.swiper-pagination-bullets-dynamic .swiper-pagination-bullet-active-prev {
    transform: scale(1);
}

.swiper-button-next:after, .swiper-button-prev:after {
    font-size: 16px !important;
}
.swiper-button-next, .swiper-button-prev {
    --swiper-navigation-color: #444652;
    background: rgba(255, 255, 255, 0.50);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 30px !important;
    height: 30px !important;
}

.color-primary,.primary-primary-500,.error-500 {
    color: #013793;
    font-family: 'AvertaStdPE-Bold';
}

.primary-primary-500 {
    color: #014ECF;
}

.error-500 {
    color: #EF4444
}

.text-alyamore {
    color: #FFF;
    text-shadow: 0px 4px 4px rgba(0, 0, 0, 0.25);
    font-family: "SVN-Rosellinda Alyamore";
    font-size: 80px;
    font-style: normal;
    font-weight: 400;
    line-height: 120%;
}

.list-buttons {
    margin: auto;
    max-width: 500px;
    display: flex;
    flex-flow: wrap;
    justify-content: center;
    margin-top: 10px
}

.list-buttons a {
    display: flex;
    height: 56px;
    padding: 16px;
    justify-content: center;
    align-items: center;
    border: 2px solid #014ECF;
    width: max-content;
    margin: 5px;
    text-decoration: none;
    color: #014ECF;
    font-family: 'AvertaStdPE-Bold';
}
@media (max-width: 768px) {
    header nav.navbar.navbar-expand-lg {
        padding: 0;
    }
    .logo {
        width: 100px;
    }
}
</style><style>@font-face {
